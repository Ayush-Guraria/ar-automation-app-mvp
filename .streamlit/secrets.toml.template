# Copy this file to .streamlit/secrets.toml and fill in your real key.
# secrets.toml is gitignored — never commit real credentials.

ANTHROPIC_API_KEY = "..."
CLAUDE_MODEL = "claude-sonnet-4-5"

# SendGrid — required for the autonomous agent to auto-send reminder emails
# and for the Approval Queue's "Approve and Send" button.
SENDGRID_API_KEY = "SG....."
SENDER_EMAIL = "sender@email.com"

# Demo Mode — when enabled in the "Run Agent" tab, all auto-sent emails go
# here instead of the (fictional) client_email addresses in the invoice data.
DEMO_EMAIL = "reciever@email.com"
